<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard | Sanzeet Photography</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body { background: #0F1115; color: white; display: flex; min-height: 100vh; }
        
        /* Sidebar */
        .sidebar { width: 260px; background: #1A1D24; padding: 30px; border-right: 1px solid rgba(255,255,255,0.1); }
        .sidebar h2 { color: #5CB85C; margin-bottom: 40px; font-size: 1.2rem; }
        .menu-item { padding: 15px; color: #8A8D93; cursor: pointer; transition: 0.3s; border-radius: 8px; }
        .menu-item:hover, .menu-item.active { background: #5CB85C; color: black; font-weight: 600; }

        /* Main Content */
        .main-content { flex: 1; padding: 40px; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 30px; }
        .stat-card { background: #1A1D24; padding: 25px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); text-align: center; }
        .stat-card h3 { font-size: 2rem; color: #5CB85C; margin-top: 10px; }
        .stat-card p { color: #8A8D93; font-size: 0.9rem; }
        
        /* Logout */
        .logout-btn { margin-top: 100px; color: #ff5c5c; cursor: pointer; }
    </style>
</head>
<body>

    <div class="sidebar">
        <h2>SANZEET ADMIN</h2>
        <div class="menu-item active">Dashboard</div>
        <div class="menu-item">Upload Photo</div>
        <div class="menu-item">Manage Photos</div>
        <div class="menu-item">Analytics</div>
        <div class="logout-btn" onclick="window.location.href='index.html'">⬅ Logout</div>
    </div>

    <div class="main-content">
        <h1>Dashboard Overview</h1>
        <div class="stats-grid">
            <div class="stat-card"><p>Total Photos</p><h3 id="totPhotos">0</h3></div>
            <div class="stat-card"><p>Total Views</p><h3 id="totViews">0</h3></div>
            <div class="stat-card"><p>Total Likes</p><h3 id="totLikes">0</h3></div>
        </div>
    </div>

    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-firestore.js"></script>
    <script src="script.js"></script>
</body>
</html>
